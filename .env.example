# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mineru
POSTGRES_PASSWORD=mineru123
POSTGRES_DB=mineru_pipeline
# 完整连接串 (如不设则自动拼接)
# DATABASE_URL=postgresql+asyncpg://mineru:mineru123@localhost:5432/mineru_pipeline

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_QUEUE=mineru:poll_queue

# ── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
# 双桶名称
MINIO_RAW_BUCKET=raw-docs
MINIO_PARSED_BUCKET=parsed-data
# 对外可访问的 MinIO 地址 (用于 full.md 图片路径替换)
MINIO_PUBLIC_URL=http://localhost:9000

# ── MinerU API ─────────────────────────────────────────────
MINERU_API_BASE=https://mineru.net
MINERU_API_TOKEN=your_token_here
MINERU_MODEL_VERSION=vlm
MINERU_ENABLE_OCR=false
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_LANGUAGE=ch

# ── Worker ─────────────────────────────────────────────────
POLL_INTERVAL=5
MAX_POLL_TIME=1200
